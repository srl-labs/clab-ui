{
  "name": "@srl-labs/clab-standalone",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development concurrently -k -n server,vite \"tsx watch server/index.ts\" \"sh -c 'until curl -sSf http://localhost:${PORT:-3000}/api/config >/dev/null 2>&1; do sleep 0.2; done; vite --config vite.config.ts'\"",
    "build": "vite build --config vite.config.ts && npm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=cjs --target=node24 --outfile=dist/server/index.cjs --sourcemap",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server/index.cjs",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.2",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
