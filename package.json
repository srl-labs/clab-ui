{
  "name": "clab-ui-workspace",
  "version": "0.0.1",
  "private": true,
  "description": "Workspace for the shared clab-ui package and standalone host",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/srl-labs/clab-ui.git"
  },
  "homepage": "https://github.com/srl-labs/clab-ui",
  "bugs": {
    "url": "https://github.com/srl-labs/clab-ui/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/standalone"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@srl-labs/clab-standalone",
    "build": "node esbuild.config.js",
    "build:watch": "node esbuild.config.js --dev",
    "build:dev": "node esbuild.config.js --dev",
    "build:ui-package": "npm run build --workspace=@srl-labs/clab-ui",
    "typecheck": "npm run build:ui-package && tsc --noEmit",
    "lint": "npm run typecheck && npm run lint:ts",
    "lint:ts": "oxlint --import-plugin --react-plugin --jsx-a11y-plugin .",
    "lint:ts:fix": "oxlint --import-plugin --react-plugin --jsx-a11y-plugin . --fix --fix-suggestions",
    "test:unit": "npm run build:ui-package && node --import tsx --test apps/standalone/src/**/*.test.ts packages/ui/src/**/*.test.ts",
    "test:e2e": "playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config test/e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config test/e2e/playwright.config.ts --debug",
    "pack:preview": "npm pack --dry-run --workspace=@srl-labs/clab-ui",
    "publish:ui": "npm publish --workspace=@srl-labs/clab-ui",
    "prepack": "npm run build",
    "dev:standalone": "npm run build:ui-package && npm run dev --workspace=@srl-labs/clab-standalone",
    "build:standalone": "npm run build:ui-package && npm run build --workspace=@srl-labs/clab-standalone",
    "start:standalone": "npm run start --workspace=@srl-labs/clab-standalone"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@playwright/test": "^1.58.2",
    "@types/d3-force": "^3.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.99.0",
    "@vitejs/plugin-react": "^5.1.4",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.27.3",
    "monaco-editor": "^0.55.1",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.18.1",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "yaml": "^2.8.2"
  }
}
